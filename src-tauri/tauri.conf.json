{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ari Desktop Character",
  "version": "1.2.0",
  "identifier": "app.ari.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ari Desktop Character",
        "width": 460,
        "height": 720,
        "minWidth": 400,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/desktop-character/ari/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDAwMDAwMDAwMDAwMDAwMDAKUldRempuWm1Oa1pYSmhZMlZ5YVdSak9tRjBaVzF3YjNKcGRHbHZiaTloYm1ScGJtVjBJR1Z1ZEdWa0x6RXc="
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Desktop Character contributors",
    "shortDescription": "Local AI desktop companion powered by Ollama",
    "longDescription": "Ari is a private local desktop companion with streaming chat, emotions, memory, system tray integration and Ollama model management.",
    "copyright": "Copyright © 2026 Desktop Character contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Russian"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "Ari Desktop Character"
      }
    }
  }
}
